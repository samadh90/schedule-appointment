{
  "version": "0.2.0",
  "configurations": [
    // ── Server ────────────────────────────────────────────────────────────────
    {
      "name": "Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/server",
      "console": "integratedTerminal",
      "killBehavior": "forceful",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },

    // ── Client — localhost only ───────────────────────────────────────────────
    {
      "name": "Client",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/client",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },

    // ── Client — exposed on LAN (--host) ─────────────────────────────────────
    {
      "name": "Client (--host)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev", "--", "--host"],
      "cwd": "${workspaceFolder}/client",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },

    // ── Embed dev server (:5174) ──────────────────────────────────────────────
    {
      "name": "Embed",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/embed",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "Embed (--host)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev:host"],
      "cwd": "${workspaceFolder}/embed",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ],

  "compounds": [
    // ── Both apps, localhost only ─────────────────────────────────────────────
    {
      "name": "Client (Server + Client)",
      "configurations": ["Server", "Client"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 1
      }
    },

    // ── Both apps, client exposed on LAN ─────────────────────────────────────
    {
      "name": "Client (Server + Client --host)",
      "configurations": ["Server", "Client (--host)"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 2
      }
    },

    // ── Server + Embed widget dev ─────────────────────────────────────────────
    {
      "name": "Embed (Server + Widget)",
      "configurations": ["Server", "Embed"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 3
      }
    },
    {
      "name": "Embed (Server + Widget --host)",
      "configurations": ["Server", "Embed (--host)"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 4
      }
    }
  ]
}
