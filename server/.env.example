PORT=3000
NODE_ENV=production

# Optional JSON override for business config.
# webhookUrl, bookingUrl, siteUrl, and emailFromName are tenant-level settings that live here.
# TENANT_CONFIG={"openTime":"08:00","closeTime":"17:00","timezone":"Europe/Paris","webhookUrl":"https://hooks.example.com/abc","bookingUrl":"https://booking.drsmith.com","siteUrl":"https://www.drsmith.com","emailFromName":"Dr. Smith Dental"}

# Comma-separated list of allowed frontend origins (default: http://localhost:5173)
# ALLOWED_ORIGINS=https://yoursite.com,https://www.yoursite.com

# ── Email notifications (optional) ──────────────────────────────────────────
# Gmail: enable 2-Step Verification, then create an App Password at
#   https://myaccount.google.com/apppasswords
# Use that 16-char password (without spaces) as SMTP_PASS.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=abcdabcdabcdabcd
# EMAIL_FROM=you@gmail.com
# EMAIL_LOCALE=en
# EMAIL_FROM_NAME is optional here; it can also be set per-tenant via TENANT_CONFIG
