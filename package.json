{
  "name": "schedule-appointment",
  "version": "1.0.0",
  "description": "A simple appointment scheduling web application where users can book, view, and cancel appointments.",
  "scripts": {
    "dev": "concurrently \"pnpm --filter ./server dev\" \"pnpm --filter ./client dev\"",
    "dev:embed": "concurrently \"pnpm --filter ./server dev\" \"pnpm --filter ./embed dev\"",
    "build": "pnpm --filter ./client build && pnpm --filter ./server build",
    "start": "pnpm --filter ./server start",
    "format": "prettier --write \"**/*.{ts,vue,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,js,json,css,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.8.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "vue-demi"
    ]
  }
}
